{
  "name": "simple-mind-map-mcp",
  "version": "0.1.0",
  "description": "MCP server for SimpleMindMap - AI-powered diagram generation with real-time browser preview",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "simple-mind-map-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "web-dist"
  ],
  "scripts": {
    "build": "cross-env NODE_ENV=production webpack --mode production",
    "dev": "cross-env NODE_ENV=development node ./src/index.js",
    "test01": "cross-env NODE_ENV=development node ./test/test-http-server.js",
    "test02": "cross-env NODE_ENV=development node ./src/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "open": "^10.2.0",
    "ws": "^8.19.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@babel/preset-env": "^7.28.0",
    "@types/node": "^16.11.6",
    "babel-loader": "^10.0.0",
    "webpack": "^5.98.0",
    "webpack-cli": "^6.0.1",
    "webpack-node-externals": "^3.0.0"
  },
  "keywords": [
    "mcp",
    "simple-mind-map",
    "mind-map",
    "ai",
    "claude",
    "cursor"
